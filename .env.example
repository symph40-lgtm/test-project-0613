# Supabase 프로젝트 설정 (Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 서비스 롤 키 — 서버 전용, 절대 클라이언트에 노출 금지
# Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=

# 이메일 발송 (M2 알림 채널 인증에 필요)
# Resend (https://resend.com) 계정에서 API 키 발급. 없으면 console.log fallback
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# AI 브리핑 생성 (M3 — Claude API)
# Anthropic Console에서 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# FRED API — 미국 거시경제 지표 (선택, 없으면 Yahoo Finance ^TNX 사용)
# 무료 등록: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# 장중 시황 Cron 엔드포인트 보호 (M4 — /api/cron/intraday)
# 임의 문자열로 설정. Authorization: Bearer <CRON_SECRET> 또는 ?secret=<CRON_SECRET>
CRON_SECRET=

# 한국투자증권(KIS) — 코스피200 '야간선물' 실시간 시세 (선택, 없으면 네이버 정규장만)
# KIS Developers(https://apiportal.koreainvestment.com)에서 앱 생성 후 발급. 한국투자증권 계좌 필요.
KIS_APP_KEY=
KIS_APP_SECRET=
# 야간 코스피200 선물 종목코드 (HTS/포털에서 확인, 예: 101W09 형식)
KIS_FUT_CODE=
# (선택) 시세 조회 tr_id. 기본 FHMIF10000000
KIS_FUT_TRID=
